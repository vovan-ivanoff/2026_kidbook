# GigaChat API Authorization Key
# Получить на https://developers.sber.ru/studio/ → ваш проект → Authorization key
# Это НЕ Client ID, а именно Authorization key (Base64 строка)
GIGACHAT_CREDENTIALS=
GIGACHAT_ACCESS_TOKEN=
GIGACHAT_MODEL=GigaChat-2-Max
GIGACHAT_TIMEOUT_SECONDS=180
GIGACHAT_MAX_ATTEMPTS=6
GIGACHAT_BACKOFF_BASE=2.0
GIGACHAT_VERIFY_SSL_CERTS=true
GIGACHAT_IMAGE_SIZE=1024x1024
GIGACHAT_ARTICLES_DIR=../../WEB/8.1_entertainment/articles
GIGACHAT_OUTPUT_DIR=../../WEB/8.1_entertainment/images/gigachat_generated
